# Copia este archivo como .env y rellena los valores reales

# MercadoLibre
MELI_APP_ID=your_app_id
MELI_SECRET_KEY=your_secret_key
MELI_REDIRECT_URI=https://your-domain.com/auth/callback

# Base de datos SQLite
DATABASE_PATH=./data/meli.db

# Entorno (development | production)
NODE_ENV=production

# CORS - separa múltiples orígenes con coma
# ALLOWED_ORIGINS=https://roblots.com,https://otraurl.com
